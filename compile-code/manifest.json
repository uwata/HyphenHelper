{
  "id": "com.wata.hyphenator",
  "name": "Hyphen Helper",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "22.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "hyphenatorPanel",
      "label": {
        "default": "Hyphen Helper"
      },
      "minimumSize": { "width": 250, "height": 300 },
      "preferredSize": { "width": 300, "height": 400 },
      "icons": [
        { "width": 24, "height": 24, "path": "icons/icon-24.png", "scale": [1, 2] }
      ]
    }
  ],
  "icons": [
    { "width": 24, "height": 24, "path": "icons/icon-24.png", "scale": [1, 2] },
    { "width": 48, "height": 48, "path": "icons/icon-48.png", "scale": [1, 2] },
    { "width": 96, "height": 96, "path": "icons/icon-96.png", "scale": [1, 2] }
  ],
  "manifestVersion": 4
}